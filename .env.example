# AI City Governor — Environment Variables Template

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true

# ── Database (PostgreSQL + TimescaleDB) ──────────────────────────────────────
POSTGRES_USER=city_gov
POSTGRES_PASSWORD=city_gov_pass
POSTGRES_DB=city_governor

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security (Stage 7) ────────────────────────────────────────────────────────
JWT_ISSUER=ai-city-governor
JWT_AUDIENCE=city-ops
LOGIN_RATE_LIMIT=5/minute
OPERATOR_RATE_LIMIT=60/minute
SECURITY_OPERATORS=[{"username":"admin","password_hash":"$2b$12$06.qA8uNXa5hZs9VSMzXoO/2IogqrA/hHiOE6d.afStQd/O40iQVC","role":"admin"},{"username":"operator","password_hash":"$2b$12$Ndl79g9ZZqxTs0fK6dUC/OCNgq.SfhXO0qlQp4rUp9UYRJQSNZJA6","role":"operator"},{"username":"auditor","password_hash":"$2b$12$Lr.UcvDy8YT/Wt/44acxbOatVqalTv/Vt8nIVMiJ5i6L5dup9lZd.","role":"auditor"}]
# Demo passwords for local setup only:
# admin -> AdminPass!234
# operator -> OperatorPass!234
# auditor -> AuditorPass!234

# ── ArmorIQ SDK (Stage 5) ─────────────────────────────────────────────────────
ARMORIQ_API_KEY=your_armoriq_api_key_here
ARMORIQ_BASE_URL=https://api.armoriq.io

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=city_gov_grafana

# ── Synthetic Smart City Simulator (Stage 10) ────────────────────────────────
SIMULATOR_OUTPUT_DIR=backend/data/simulator
SIMULATOR_DEFAULT_LOG_COUNT=2500
SIMULATOR_DEFAULT_SEED=2026
SIMULATOR_DEFAULT_ANOMALY_RATE=0.03

# Machine Learning (Stage 11)
ML_MODEL_DIR=backend/data/ml
ML_ANOMALY_ESCALATION_ENABLED=true
ML_ANOMALY_MIN_CONFIDENCE=0.55
